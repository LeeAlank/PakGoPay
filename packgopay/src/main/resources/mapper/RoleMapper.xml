<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pakgopay.mapper.RoleMapper">
    <resultMap id="roleMap" type="com.pakgopay.mapper.dto.Role">
        <result column="role_id" property="roleId" javaType="java.lang.Integer"/>
        <result column="role_name" property="roleName" javaType="java.lang.String"/>
        <result column="remark" property="remark" javaType="java.lang.String"/>
        <result column="create_time" property="createTime" javaType="java.lang.Long"/>
        <result column="update_time" property="updateTime" javaType="java.lang.Long"/>
    </resultMap>

    <select id="queryRoleInfoByUserId" resultType="java.lang.Integer">
        SELECT role_id from user_role where user_id = #{userId}
    </select>

    <select id="getRoleList" resultMap="roleMap">
        SELECT role_id, role_name, remark, create_time, update_time from role order by role_id asc;
    </select>

    <select id="getRoleListByRoleName" resultMap="roleMap">
        SELECT role_id, role_name, remark, create_time, update_time from role where role_name = #{roleName} order by role_id asc
    </select>

    <sql id="RoleWhere">
        <where>
            <if test="roleName != null and roleName != ''">
                AND role_name = #{roleName}
            </if>
        </where>
    </sql>

    <select id="countByQuery" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM role
        <include refid="RoleWhere"/>
    </select>

    <select id="pageByQuery" resultMap="roleMap">
        SELECT role_id, role_name, remark, create_time, update_time
        FROM role
        <include refid="RoleWhere"/>
        ORDER BY role_id ASC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <insert id="addNewRole" parameterType="com.pakgopay.mapper.dto.Role">
        INSERT INTO role (role_name, remark, create_time, update_time) values (#{role.roleName}, #{role.remark}, #{role.createTime}, #{role.updateTime})
    </insert>

    <update id="updateRole" parameterType="com.pakgopay.mapper.dto.Role">
        UPDATE role
        SET
            role_name = #{role.roleName},
            remark = #{role.remark},
            update_time = #{role.updateTime}
        WHERE role_id = #{role.roleId}
    </update>

    <delete id="deleteRole">
        DELETE FROM role where role_id = #{roleId}
    </delete>
</mapper>
